# --- SERVER CONFIG ---
SERVER_PORT=5000
MONGODB_URI=mongodb://localhost:27017/mytube
CLIENT_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_key

# --- CLIENT CONFIG ---
CLIENT_PORT=3000
SESSION_SECRET=your_session_secret_key
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key

# --- GOOGLE AUTH CONFIG ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback/google

# --- FACEBOOK AUTH CONFIG ---
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/callback/facebook

# --- GITHUB AUTH CONFIG ---
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback/github

# --- DISCORD AUTH CONFIG ---
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/callback/discord

# --- CLOUDINARY CONFIG ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- PAYOS CONFIG ---
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# --- SEPAY & NGROK INTEGRATION CONFIG ---
SEPAY_API_KEY=your_sepay_api_key
NGROK_AUTHTOKEN=your_ngrok_authtoken
ADMIN_MB_BANK_ACCOUNT=1234567890
ADMIN_MB_BANK_NAME=Your Bank Name