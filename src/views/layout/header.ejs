<header class="main-header">
    <div class="header-container">
        <div id="menu-btn" class="icon-btn">
            <i class="fa-solid fa-bars"></i>
        </div>

        <div class="logo">
            <div class="logo-img"></div>
            <h1>MyTube<sup style="font-size: 9px;"> VN</sup></h1>
        </div>
        
        <div class="search-box">
            <input type="text" placeholder="Tìm kiếm">
            <button class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>

        <div class="icon-btn"><a href="/notifications"><i class="fa-solid fa-bell"></i></a></div>
        
        <div class="user-auth-wrapper">
            <div id="user-btn" class="icon-btn">
                <% if (user) { %>
                    <img src="<%= (user.avatar) ? user.avatar : '/assets/img/avata.jpg' %>" 
                        alt="Avatar" 
                        style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid var(--glass-border);">
                <% } else { %>
                    <i class="fa-solid fa-user"></i>
                <% } %>
            </div>
        </div>

        <div id="auth-popup" class="auth-dropdown">
            <div class="popup-arrow"></div>
            
            <% if (user) { %>
                <h3>Chào, <%= user.username %></h3>
                <p style="font-size: 11px; word-break: break-all;">
                    <%= user.phone ? user.phone : (user.email ? user.email : '') %>
                </p>
                <hr>
                <ul class="user-menu-list" style="list-style: none; padding: 0; margin: 0;">
                    <li><a href="/profile" style="color: #fff; text-decoration: none; display: block; padding: 8px 0;"><i class="fa-solid fa-circle-user"></i> Xem Profile</a></li>
                    <li><a href="/change-password" style="color: #fff; text-decoration: none; display: block; padding: 8px 0;"><i class="fa-solid fa-key"></i> Đổi mật khẩu</a></li>
                    <hr>
                    <li><a href="/logout" style="color: #ff4d4f; text-decoration: none; display: block; padding: 8px 0; font-weight: bold;"><i class="fa-solid fa-right-from-bracket"></i> Đăng xuất</a></li>
                </ul>

            <% } else { %>
                <div id="auth-container">
                    <div id="login-section">
                        <h3>Đăng nhập</h3>
                        <form id="login-form" class="auth-form">
                            <input type="text" name="phone" placeholder="Số điện thoại" required>
                            <input type="password" name="password" placeholder="Mật khẩu" required>
                            <button type="submit" class="btn-primary-form">Đăng nhập</button>
                        </form>
                        <p class="toggle-text">Chưa có tài khoản? <span onclick="toggleAuth('register')">Đăng ký ngay</span></p>
                    </div>

                    <div id="register-section" style="display: none;">
                        <h3>Đăng ký</h3>
                        <form id="register-form" class="auth-form">
                            <input type="text" name="username" placeholder="Tên của bạn" required>
                            <input type="text" name="phone" placeholder="Số điện thoại" required>
                            <input type="password" name="password" placeholder="Mật khẩu" required>
                            <button type="submit" class="btn-primary-form">Tạo tài khoản</button>
                        </form>
                        <p class="toggle-text">Đã có tài khoản? <span onclick="toggleAuth('login')">Đăng nhập</span></p>
                    </div>

                    <div class="divider"><span>HOẶC</span></div>

                    <a href="/auth/google" class="btn-google">
                        <img src="https://www.svgrepo.com/show/355037/google.svg" alt="G">
                        Tiếp tục với Google
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</header>


