<div class="auth-container">
    <div class="auth-box">
        <h1>Đăng nhập MyTube</h1>
        <form action="/auth/login" method="POST">
            <div class="input-group">
                <label for="email">Email hoặc Số điện thoại</label>
                <input id="email" name="identifier" type="text" placeholder="Nhập email hoặc SĐT" required>
            </div>
            
            <div class="input-group">
                <label for="password">Mật khẩu</label>
                <input id="password" name="password" type="password" placeholder="Nhập mật khẩu" required>
            </div>

            <div class="input-group">
                <label for="re-password">Xác nhận mật khẩu</label>
                <input id="re-password" name="re-password" type="password" placeholder="Nhập lại mật khẩu" required>
            </div>

            <button type="submit" class="btn-submit">Tiếp theo</button>
        </form>

        <div class="divider"><span>hoặc</span></div>

    </div>
</div>