<!DOCTYPE html>
<html lang="vi">
	<%- include('../layout/head') %>

	<body>

		<div id="hero-banner-container">
			<img src="/assets/img/banner1.jpg" alt="Banner" class="hero-image active">
            <img src="/assets/img/banner2.png" alt="Banner" class="hero-image">
			<div class="banner-overlay"></div>
		</div>

		<%- include('../layout/header') %>

		<main>
            <div class="video-grid">
                <% 
                let displayVideos = Array.isArray(videos) ? videos : (videos ? [videos] : []); 
                %>

                <% if (displayVideos.length > 0) { %>
                    <% displayVideos.forEach(video => { %>
                        <div class="video-card">
                            <a href="/watch/<%= video.video_id %>">
                                <div class="thumbnail-container">
                                    <img src="/uploads/<%= video.thumbnail_url %>" 
                                        onerror="this.src='/assets/img/default-thumb.jpg'"
                                        alt="<%= video.title %>">
                                </div>

                                <div class="video-content">
                                    <div class="channel-avatar">
                                        <img src="<%= (video.channel_avatar) ? '/uploads/' + video.channel_avatar : '/assets/img/avata.jpg' %>" 
                                            onerror="this.src='/assets/img/avata.jpg'"
                                            alt="avatar">
                                    </div>
                                    <div class="video-text">
                                        <h3 class="video-title"><%= video.title %></h3>
                                        <p class="channel-name"><%= video.channel_name || 'Kênh hệ thống' %></p>
                                        <p class="video-meta"><%= video.view_count %> lượt xem</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>Không tìm thấy video nào trong mảng dữ liệu.</p>
                <% } %>
            </div>
        </main>

		<script src="/assets/script/home.js"></script>
	</body>
</html>