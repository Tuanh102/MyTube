<!DOCTYPE html>
<html lang="vi">
<%- include('../layout/head') %>
<body>
    <%- include('../layout/header') %>

    <main class="watch-container">

        <!-- ===== VIDEO CHÍNH (7 phần) ===== -->
        <div class="video-main-content">

            <!-- Player -->
            <div class="video-player-wrapper">
                <video controls autoplay width="100%">
                    <source src="/uploads/<%= video.video_url %>" type="video/mp4">
                    Trình duyệt của bạn không hỗ trợ phát video.
                </video>
            </div>

            <!-- Tiêu đề -->
            <h1 class="video-title"><%= video.title %></h1>

            <!-- Meta: lượt xem + ngày -->
            <p class="video-views">
                <%= video.view_count.toLocaleString('vi-VN') %> lượt xem
                &bull;
                <%= new Date(video.uploaded_at).toLocaleDateString('vi-VN') %>
            </p>

            <!-- Thanh kênh + actions -->
            <div class="video-meta-wrapper">

                <!-- Kênh -->
                <div class="channel-info">
                    <img src="<%= (video.channel_avatar) ? '/uploads/' + video.channel_avatar : '/assets/img/avata.jpg' %>"
                         class="channel-img" alt="avatar">
                    <div class="channel-text">
                        <p class="channel-name-detail"><%= video.channel_name %></p>
                        <p class="sub-count"><%= (video.sub_count || 0).toLocaleString('vi-VN') %> người đăng ký</p>
                    </div>

                    <!-- Nút Đăng ký — chỉ hiện khi đã login -->
                    <% if (user) { %>
                        <button class="btn-sub <%= video.isSubscribed ? 'subscribed' : '' %>"
                                id="btn-subscribe"
                                data-channel-id="<%= video.channel_id %>">
                            <%= video.isSubscribed ? 'Đã theo dõi' : 'Theo dõi' %>
                        </button>
                    <% } else { %>
                        <button class="btn-sub" onclick="requireLogin()">Theo dõi</button>
                    <% } %>
                </div>

                <!-- Actions: Like, Lưu, Chia sẻ -->
                <div class="video-actions">

                    <!-- Like -->
                    <% if (user) { %>
                        <button class="btn-action <%= video.isLiked ? 'active' : '' %>"
                                id="btn-like"
                                data-video-id="<%= video.video_id %>">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="<%= video.isLiked ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                            <span id="like-count"><%= (video.like_count || 0).toLocaleString('vi-VN') %></span>
                        </button>
                    <% } else { %>
                        <button class="btn-action" onclick="requireLogin()">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                            <span><%= (video.like_count || 0).toLocaleString('vi-VN') %></span>
                        </button>
                    <% } %>

                    <!-- Lưu vào playlist -->
                    <% if (user) { %>
                        <button class="btn-action" id="btn-save" data-video-id="<%= video.video_id %>">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                            Lưu
                        </button>
                    <% } else { %>
                        <button class="btn-action" onclick="requireLogin()">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                            Lưu
                        </button>
                    <% } %>

                    <!-- Chia sẻ (sao chép link) -->
                    <button class="btn-action" id="btn-share">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        Chia sẻ
                    </button>

                </div>
            </div>

            <!-- Mô tả -->
            <div class="video-description" id="video-desc">
                <div class="desc-content" id="desc-text">
                    <%- video.describe ? video.describe.replace(/\n/g, '<br>') : 'Không có mô tả.' %>
                </div>
                <button class="btn-toggle-desc" id="btn-toggle-desc">Xem thêm</button>
            </div>

            <!-- ===== BÌNH LUẬN ===== -->
            <div class="comments-section">
                <h3 class="comments-title"><%= (video.comment_count || 0).toLocaleString('vi-VN') %> bình luận</h3>

                <!-- Ô nhập comment — chỉ khi đăng nhập -->
                <% if (user) { %>
                    <div class="comment-input-wrapper">
                        <img src="<%= user.avatar || '/assets/img/avata.jpg' %>" class="comment-avatar" alt="avatar">
                        <div class="comment-input-area">
                            <textarea id="comment-input" placeholder="Thêm bình luận..." rows="1"></textarea>
                            <div class="comment-actions" id="comment-actions" style="display:none">
                                <button class="btn-cancel-comment" id="btn-cancel-comment">Hủy</button>
                                <button class="btn-submit-comment" id="btn-submit-comment" data-video-id="<%= video.video_id %>">Bình luận</button>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="comment-login-notice" onclick="requireLogin()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Đăng nhập để bình luận
                    </div>
                <% } %>

                <!-- Danh sách comment -->
                <div class="comments-list" id="comments-list">
                    <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
                        <% comments.forEach(c => { %>
                            <div class="comment-item">
                                <img src="<%= c.avatar || '/assets/img/avata.jpg' %>" class="comment-avatar" alt="avatar">
                                <div class="comment-body">
                                    <div class="comment-header">
                                        <span class="comment-username"><%= c.username %></span>
                                        <span class="comment-date"><%= new Date(c.created_at).toLocaleDateString('vi-VN') %></span>
                                    </div>
                                    <p class="comment-content"><%= c.content %></p>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="no-comments">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                    <% } %>
                </div>
            </div>

        </div><!-- end video-main-content -->

        <!-- ===== SIDEBAR VIDEO GỢI Ý (3 phần, tối đa 20 video) ===== -->
        <aside class="video-sidebar">
            <h3 class="sidebar-title">Video gợi ý</h3>

            <% if (typeof relatedVideos !== 'undefined' && relatedVideos.length > 0) { %>
                <% relatedVideos.slice(0, 20).forEach(item => { %>
                    <div class="side-video-card">
                        <a href="/watch/<%= item.video_id %>" class="side-link">
                            <div class="side-thumb">
                                <img src="/uploads/<%= item.thumbnail_url %>" alt="<%= item.title %>"
                                     onerror="this.src='/assets/img/thumb-default.jpg'">
                            </div>
                            <div class="side-info">
                                <h4 class="side-title"><%= item.title %></h4>
                                <p class="side-channel"><%= item.channel_name %></p>
                                <p class="side-meta"><%= item.view_count.toLocaleString('vi-VN') %> lượt xem</p>
                            </div>
                        </a>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="color:#aaa; font-size:14px;">Không có video gợi ý.</p>
            <% } %>
        </aside>

    </main>

    <!-- Toast thông báo -->
    <div class="toast" id="toast"></div>

    <!-- Modal Lưu playlist -->
    <div class="modal-overlay" id="modal-save" style="display:none">
        <div class="modal-box">
            <div class="modal-header">
                <h4>Lưu vào playlist</h4>
                <button class="modal-close" id="modal-close">&times;</button>
            </div>
            <div class="modal-body" id="playlist-list">
                <p style="color:#aaa">Đang tải...</p>
            </div>
            <div class="modal-footer">
                <input type="text" id="new-playlist-name" placeholder="Tạo playlist mới..." />
                <button class="btn-create-playlist" id="btn-create-playlist">Tạo</button>
            </div>
        </div>
    </div>

    <!-- Modal yêu cầu đăng nhập -->
    <div class="modal-overlay" id="modal-login" style="display:none">
        <div class="modal-box modal-login-box">
            <h4>Đăng nhập để tiếp tục</h4>
            <p>Bạn cần đăng nhập để sử dụng tính năng này.</p>
            <div style="display:flex;gap:10px;justify-content:center;margin-top:20px">
                <button class="btn-cancel-comment" onclick="document.getElementById('modal-login').style.display='none'">Hủy</button>
                <button class="btn-submit-comment" onclick="openHeaderLogin()">Đăng nhập</button>
            </div>
        </div>
    </div>

    <script src="/assets/script/watch.js"></script>
</body>
</html>
